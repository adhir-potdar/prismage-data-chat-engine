# ── Database ──────────────────────────────────────────────────────────────────
# SQLAlchemy connection URL for your data warehouse / database
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ── LLM ───────────────────────────────────────────────────────────────────────
# Provider: "openai" or "anthropic"
PRISMAGE_LLM_PROVIDER=openai

# Model name — leave blank to use the provider default (gpt-4o / claude-sonnet-4-6)
PRISMAGE_LLM_MODEL=gpt-4o-mini

# API keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Table routing ─────────────────────────────────────────────────────────────
# "embedding" (semantic similarity, default) or "affinity" (set-intersection from JSON config)
PRISMAGE_ROUTER_MODE=embedding

# ── Embeddings (used when PRISMAGE_ROUTER_MODE=embedding) ────────────────────
# Provider: "openai" or "voyage"
PRISMAGE_EMBEDDING_PROVIDER=openai

# Embedding model (OpenAI default: text-embedding-3-small)
PRISMAGE_EMBEDDING_MODEL=text-embedding-3-small

# Path to on-disk embedding cache — leave blank to disable caching
PRISMAGE_EMBEDDING_CACHE_PATH=.cache/metadata_embeddings.json

# Voyage AI key — only required when PRISMAGE_EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=

# ── LangSmith tracing (optional) ─────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=prismage-data-chat

# ── Config paths ──────────────────────────────────────────────────────────────
# Paths to metadata and prompt JSON directories (relative to working directory)
PRISMAGE_CONFIG_DIR=config/metadata
PRISMAGE_PROMPTS_DIR=config/prompts

# ── Query pipeline ────────────────────────────────────────────────────────────
# Set to "false" to disable the LangChain SQL chain fallback for low-confidence queries
PRISMAGE_ENABLE_FALLBACK=true
