{
  "formulas": [
    { "name": "ach_pct_mtd", "display": "Ach % MTD", "expression": "SUM({cymtd}) / NULLIF(SUM({tgt}), 0) * 100", "components": ["cymtd", "tgt"], "runtime_vars": [], "window": false },
    { "name": "mtd_gr_pct", "display": "MTD Gr %", "expression": "(SUM({cymtd}) / NULLIF(SUM({lymtd}), 0) - 1) * 100", "components": ["cymtd", "lymtd"], "runtime_vars": [], "window": false },
    { "name": "ytd_ach_pct", "display": "YTD Ach %", "expression": "SUM({ty_ytd}) / NULLIF(SUM({ytd_tgt}), 0) * 100", "components": ["ty_ytd", "ytd_tgt"], "runtime_vars": [], "window": false },
